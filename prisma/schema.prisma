generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MANAGING_DIRECTOR
  MANAGER
  TEAM_LEAD
}

enum WorkflowStatus {
  PENDING
  APPROVED
  REJECTED
}

enum EmployeeStatus {
  ACTIVE
  LEFT
}

enum NotificationType {
  PROMOTION_SUBMITTED
  PROMOTION_REVIEWED
  SALARY_SUBMITTED
  SALARY_REVIEWED
  REVIEW_ASSIGNED
}

enum CycleStatus {
  DRAFT
  OPEN
  CLOSED
}

enum ReviewStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

model User {
  id                     String    @id @default(cuid())
  name                   String
  email                  String    @unique
  password               String?
  passwordSetupToken     String?   @unique
  passwordSetupExpiresAt DateTime?
  profileImageUrl        String?
  gender                 String?
  role                   Role
  reportsToId            String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  reportsTo           User?  @relation("ReportsTo", fields: [reportsToId], references: [id], onDelete: SetNull)
  directReports       User[] @relation("ReportsTo")

  teamAccess          TeamAccess[]
  promotionRequests   PromotionRequest[]  @relation("RecommendedBy")
  promotionReviews    PromotionRequest[]  @relation("ReviewedBy")
  promotionSubject    PromotionRequest[]  @relation("PromotionSubject")
  salaryRequests      SalaryHikeRequest[] @relation("SalaryRecommendedBy")
  salaryReviews       SalaryHikeRequest[] @relation("SalaryReviewedBy")
  salarySubject       SalaryHikeRequest[] @relation("SalarySubject")
  performanceNotes    PerformanceRecord[]
  notifications       Notification[]
  cyclesCreated       ReviewCycle[]
  reviewsAssigned     CycleReview[] @relation("ReviewReviewer")
}

model Team {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  teamAccess        TeamAccess[]
  employees         Employee[]
  promotionRequests PromotionRequest[]
  salaryRequests    SalaryHikeRequest[]
  reviewCycleTeams  ReviewCycleTeam[]
}

model TeamAccess {
  id     String @id @default(cuid())
  userId String
  teamId String
  role   Role

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
}

model Employee {
  id        String         @id @default(cuid())
  name      String
  email     String
  title     String
  joinDate  DateTime
  status    EmployeeStatus @default(ACTIVE)
  leftDate  DateTime?
  teamId    String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  team               Team                @relation(fields: [teamId], references: [id], onDelete: Cascade)
  performanceRecords PerformanceRecord[]
  promotionRequests  PromotionRequest[]
  salaryRequests     SalaryHikeRequest[]
  anniversaryEmails  AnniversaryEmail[]
  cycleReviews       CycleReview[]
}

model PerformanceRecord {
  id         String   @id @default(cuid())
  employeeId String
  rating     Int
  notes      String
  period     String
  createdBy  String?
  createdAt  DateTime @default(now())

  employee    Employee                @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  author      User?                   @relation(fields: [createdBy], references: [id], onDelete: SetNull)
  attachments PerformanceAttachment[]
}

model PerformanceAttachment {
  id                  String   @id @default(cuid())
  performanceRecordId String
  filename            String
  mimeType            String
  sizeBytes           Int
  dataUrl             String
  createdAt           DateTime @default(now())

  record PerformanceRecord @relation(fields: [performanceRecordId], references: [id], onDelete: Cascade)
}

model PromotionRequest {
  id              String         @id @default(cuid())
  // Subject of the workflow: exactly one of employeeId or subjectUserId is set.
  employeeId      String?
  subjectUserId   String?
  teamId          String
  recommendedBy   String?
  currentTitle    String
  proposedTitle   String
  justification   String
  status          WorkflowStatus @default(PENDING)
  reviewedBy      String?
  reviewNote      String?
  createdAt       DateTime       @default(now())
  reviewedAt      DateTime?

  employee    Employee? @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  subjectUser User?     @relation("PromotionSubject", fields: [subjectUserId], references: [id], onDelete: Cascade)
  team        Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  recommender User?     @relation("RecommendedBy", fields: [recommendedBy], references: [id], onDelete: SetNull)
  reviewer    User?     @relation("ReviewedBy", fields: [reviewedBy], references: [id], onDelete: SetNull)
}

model SalaryHikeRequest {
  id              String         @id @default(cuid())
  employeeId      String?
  subjectUserId   String?
  teamId          String
  recommendedBy   String?
  currentSalary   Float
  proposedSalary  Float
  justification   String
  status          WorkflowStatus @default(PENDING)
  reviewedBy      String?
  reviewNote      String?
  createdAt       DateTime       @default(now())
  reviewedAt      DateTime?

  employee    Employee? @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  subjectUser User?     @relation("SalarySubject", fields: [subjectUserId], references: [id], onDelete: Cascade)
  team        Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  recommender User?     @relation("SalaryRecommendedBy", fields: [recommendedBy], references: [id], onDelete: SetNull)
  reviewer    User?     @relation("SalaryReviewedBy", fields: [reviewedBy], references: [id], onDelete: SetNull)
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  link      String?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
}

model AnniversaryEmail {
  id         String   @id @default(cuid())
  employeeId String
  year       Int
  sentAt     DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, year])
}

model ReviewCycle {
  id          String      @id @default(cuid())
  name        String
  description String?
  startDate   DateTime
  endDate     DateTime
  status      CycleStatus @default(DRAFT)
  createdBy   String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  author  User?             @relation(fields: [createdBy], references: [id], onDelete: SetNull)
  teams   ReviewCycleTeam[]
  reviews CycleReview[]
}

// If a cycle has zero ReviewCycleTeam rows, it applies to ALL teams.
// Otherwise it's limited to the linked teams.
model ReviewCycleTeam {
  id      String @id @default(cuid())
  cycleId String
  teamId  String

  cycle ReviewCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  team  Team        @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([cycleId, teamId])
}

model CycleReview {
  id           String       @id @default(cuid())
  cycleId      String
  employeeId   String
  reviewerId   String?
  rating       Int?
  strengths    String?
  improvements String?
  goals        String?
  status       ReviewStatus @default(NOT_STARTED)
  submittedAt  DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  cycle    ReviewCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  employee Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  reviewer User?       @relation("ReviewReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)

  @@unique([cycleId, employeeId])
  @@index([reviewerId, status])
}
