# Database — Supabase Postgres connection strings
# DATABASE_URL: Transaction pooler (port 6543) — used by the app at runtime
# DIRECT_URL:   Direct/Session connection (port 5432) — used by prisma migrate
DATABASE_URL="postgresql://postgres.xxxxx:YOUR-PASSWORD@aws-1-us-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxxx:YOUR-PASSWORD@aws-1-us-west-2.pooler.supabase.com:5432/postgres"

# Session secret — generate with: openssl rand -base64 32
SESSION_SECRET="replace-with-a-random-32-char-secret"

# Cron security token — used to protect the /api/cron/* routes
CRON_SECRET="replace-with-cron-secret"

# Email (Nodemailer) — configure with your SMTP provider
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="your-email@example.com"
SMTP_PASS="your-email-password"
EMAIL_FROM="TeamTracker <noreply@example.com>"
